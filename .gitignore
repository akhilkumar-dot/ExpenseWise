# ============================================
# ExpenseWise — .gitignore
# Java 17 | Spring Boot 3 | Maven | MongoDB
# ============================================

# ── Maven build output ──────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── Spring Boot packaged jar ─────────────────
*.jar
*.war
*.ear
*.nar

# ── IDE — IntelliJ IDEA ──────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ── IDE — VS Code ────────────────────────────
.vscode/
*.code-workspace

# ── IDE — Eclipse ────────────────────────────
.classpath
.project
.settings/
.factorypath
bin/

# ── IDE — NetBeans ───────────────────────────
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ── OS generated files ───────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Sensitive configuration ──────────────────
# Keep application.properties out of git — use application.properties.example instead
src/main/resources/application.properties
src/main/resources/application-prod.properties
src/main/resources/application-local.properties

# ── Logs ─────────────────────────────────────
*.log
logs/
log/

# ── Maven wrapper (keep the jar, ignore OS scripts if desired) ──
.mvn/wrapper/maven-wrapper.properties

# ── Test coverage ─────────────────────────────
/coverage/

# ── Node (in case frontend is added later) ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
